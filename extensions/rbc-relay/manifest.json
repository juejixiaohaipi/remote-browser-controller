{
  "manifest_version": 3,
  "name": "RBC Relay",
  "version": "1.0.0",
  "description": "通过本地 Relay 连接远程 BAP Gateway（需要先运行 relay.exe）",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
