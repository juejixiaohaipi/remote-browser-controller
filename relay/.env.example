# BAP Gateway WebSocket URL (required, include /ws path)
RBC_GATEWAY_URL=ws://your-server:3000/ws

# Local relay listen port (Chrome extension connects here)
RBC_RELAY_PORT=17799

# Device identity (seen by BAP Gateway)
RBC_DEVICE_ID=rbc-relay
RBC_DEVICE_NAME=RBC-Relay

# Auth token (required, must match BAP server's DEFAULT_TOKEN)
RBC_RELAY_TOKEN=your-token-here
