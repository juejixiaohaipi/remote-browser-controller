{
  "name": "rbc-relay",
  "version": "1.0.0",
  "description": "Local relay that bridges Chrome extension to remote BAP Gateway",
  "main": "relay.js",
  "scripts": {
    "start": "node relay.js",
    "build:linux": "pkg relay.js -t node22-linux-x64 -o dist/relay",
    "build:win": "pkg relay.js -t node22-win-x64 -o dist/relay.exe"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
